// Prueba simple de funciones

func suma(a int32, b int32) int32 {
    println("En suma, a = ")
    println(a)
    println("En suma, b = ")
    println(b)
    var resultado int32
    resultado = a + b
    println("resultado = ")
    println(resultado)
    return resultado
}

func main() {
    println("Llamando a suma(10, 5)")
    var x int32
    x = suma(10, 5)
    println("El resultado es:")
    println(x)
}
